<Project Sdk="Microsoft.NET.Sdk">

    <ItemGroup>
      <ProjectReference Include="BookShelfAPI.Domain\BookShelfAPI.Domain.csproj" />
      <ProjectReference Include="BookShelfAPI.Application\BookShelfAPI.Application.csproj" />
    </ItemGroup>

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
        <DefaultItemExcludes>$(DefaultItemExcludes);BookShelfAPI.Domain\**;BookShelfAPI.Application\**</DefaultItemExcludes>
    </PropertyGroup>

</Project>
